# Database
DATABASE_URL=postgresql://user:password@localhost:5432/glamorous

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Email Configuration (Optional - notifications won't be sent if not configured)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@glamorous-guesthouse.com

# Server
NODE_ENV=development
PORT=5000
